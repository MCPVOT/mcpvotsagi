{
  "components": {
    "trading_system": {
      "script": "ultimate_trading_system_v3.py",
      "port": 8890,
      "health_endpoint": "/health",
      "critical": true,
      "auto_restart": true,
      "max_restarts": 3,
      "description": "Core RL trading system with Jupiter DEX integration",
      "dependencies": ["jupiter_api_wrapper", "mcp_server"]
    },
    "trading_dashboard": {
      "script": "ultimate_trading_dashboard_v3_fixed.py",
      "port": 8891,
      "health_endpoint": "/health",
      "critical": false,
      "auto_restart": true,
      "max_restarts": 3,
      "description": "Real-time trading dashboard with cyberpunk UI",
      "dependencies": ["trading_system"]
    },
    "claudia_integration": {
      "script": "claudia_production_integration.py",
      "port": 8892,
      "health_endpoint": "/health",
      "critical": true,
      "auto_restart": true,
      "max_restarts": 5,
      "description": "Claudia AI integration for self-improvement",
      "dependencies": []
    },
    "watchyourlan_integration": {
      "script": "watchyourlan_complete_integration.py",
      "port": 8893,
      "health_endpoint": "/health",
      "critical": false,
      "auto_restart": true,
      "max_restarts": 3,
      "description": "Network monitoring and security system",
      "dependencies": []
    },
    "mcp_server": {
      "script": "oracle_mcp_server.py",
      "port": 8894,
      "health_endpoint": "/health",
      "critical": true,
      "auto_restart": true,
      "max_restarts": 3,
      "description": "MCP server for knowledge graph and memory",
      "dependencies": []
    },
    "deepseek_integration": {
      "script": "deepseek_r1_trading_agent_enhanced.py",
      "port": 8895,
      "health_endpoint": "/health",
      "critical": false,
      "auto_restart": true,
      "max_restarts": 3,
      "description": "DeepSeek R1 enhanced trading agent",
      "dependencies": ["trading_system"]
    }
  },
  "monitoring": {
    "health_check_interval": 30,
    "metrics_retention_days": 7,
    "alert_thresholds": {
      "cpu_usage": 80,
      "memory_usage": 85,
      "disk_usage": 90,
      "component_health": 70,
      "response_time": 5000,
      "error_rate": 0.05
    },
    "notification_channels": {
      "console": true,
      "file": true,
      "webhook": false,
      "email": false
    }
  },
  "self_improvement": {
    "enabled": true,
    "cycle_interval_hours": 4,
    "analysis_models": [
      "claude-3-opus-4",
      "claude-3-sonnet-4",
      "qwen2.5-coder:latest",
      "llama3.2:latest"
    ],
    "optimization_targets": [
      "trading_performance",
      "system_efficiency",
      "resource_usage",
      "error_rates",
      "latency",
      "throughput"
    ],
    "improvement_metrics": {
      "min_improvement_threshold": 2.0,
      "max_optimization_attempts": 3,
      "rollback_on_degradation": true,
      "performance_baseline_days": 3
    }
  },
  "security": {
    "authentication": {
      "enabled": false,
      "method": "api_key",
      "api_key": "agi_system_v3_secure"
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 100,
      "burst_limit": 20
    },
    "network_security": {
      "allowed_hosts": ["localhost", "127.0.0.1"],
      "cors_enabled": true,
      "https_redirect": false
    }
  },
  "trading": {
    "risk_management": {
      "max_position_size": 0.1,
      "max_daily_loss": 0.05,
      "stop_loss_threshold": 0.02,
      "take_profit_threshold": 0.03
    },
    "markets": {
      "primary": "SOL/USDC",
      "secondary": ["BTC/USDC", "ETH/USDC", "RAY/USDC"],
      "excluded": []
    },
    "strategies": {
      "enabled": ["dqn_rl", "random_forest", "technical_analysis"],
      "weights": {
        "dqn_rl": 0.4,
        "random_forest": 0.3,
        "technical_analysis": 0.3
      }
    }
  },
  "infrastructure": {
    "database": {
      "type": "sqlite",
      "path": "ultimate_agi_system.db",
      "backup_interval_hours": 6,
      "retention_days": 30
    },
    "logging": {
      "level": "INFO",
      "file": "ultimate_agi_orchestrator_v3.log",
      "max_size_mb": 100,
      "backup_count": 5
    },
    "storage": {
      "base_path": "F:\\MCPVotsAGI\\storage",
      "cache_size_mb": 500,
      "cleanup_interval_hours": 24
    }
  },
  "performance": {
    "max_concurrent_requests": 50,
    "request_timeout_seconds": 30,
    "connection_pool_size": 20,
    "cache_ttl_seconds": 300,
    "batch_processing": {
      "enabled": true,
      "batch_size": 100,
      "flush_interval_seconds": 60
    }
  },
  "deployment": {
    "environment": "production",
    "version": "3.0.0",
    "build_date": "2025-07-06",
    "auto_scaling": {
      "enabled": false,
      "min_instances": 1,
      "max_instances": 3,
      "cpu_threshold": 70
    }
  }
}
