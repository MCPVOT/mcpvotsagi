{
  "extends": [
    "next/core-web-vitals",
    "next/typescript"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["error", { 
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "@next/next/no-img-element": "off"
  },
  "overrides": [
    {
      "files": ["external-libs/**/*"],
      "rules": {
        "@typescript-eslint/no-unused-vars": "off",
        "@next/next/no-html-link-for-pages": "off"
      }
    }
  ]
}
