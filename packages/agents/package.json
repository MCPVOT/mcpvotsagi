{
  "name": "@mcpvotsagi/agents",
  "version": "3.0.0",
  "description": "AI Agent system for MCPVotsAGI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "deepseek",
    "context7",
    "oracle",
    "trading"
  ],
  "dependencies": {
    "@mcpvotsagi/core": "workspace:*",
    "@mcpvotsagi/types": "workspace:*",
    "openai": "^4.24.7",
    "anthropic": "^0.17.1",
    "axios": "^1.6.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
