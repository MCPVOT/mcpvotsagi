{
  "mcpServers": {
    "ultimate-agi": {
      "name": "Ultimate AGI System",
      "description": "DeepSeek-R1 powered AGI with memory, RL, and multi-agent capabilities",
      "command": "python",
      "args": ["C:/Workspace/MCPVotsAGI/src/core/ultimate_agi_mcp_bridge.py"],
      "port": 3333,
      "capabilities": {
        "chat": {
          "description": "Chat with DeepSeek-R1 using full AGI capabilities",
          "parameters": {
            "prompt": {
              "type": "string",
              "description": "The prompt to send to DeepSeek-R1"
            },
            "use_tools": {
              "type": "array",
              "description": "List of MCP tools DeepSeek can use",
              "items": {
                "type": "string",
                "enum": ["filesystem", "github", "memory", "browser", "solana"]
              }
            },
            "use_memory": {
              "type": "boolean",
              "description": "Whether to use memory context",
              "default": true
            },
            "use_rl": {
              "type": "boolean", 
              "description": "Whether to consult RL models",
              "default": false
            }
          }
        },
        "memory_search": {
          "description": "Search the Ultimate Memory System",
          "parameters": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "top_k": {
              "type": "integer",
              "description": "Number of results to return",
              "default": 5
            },
            "memory_type": {
              "type": "string",
              "enum": ["short_term", "long_term", "episodic", "semantic", "procedural"],
              "description": "Type of memory to search"
            }
          }
        },
        "knowledge_query": {
          "description": "Query the knowledge graph",
          "parameters": {
            "query": {
              "type": "string",
              "description": "Knowledge query"
            },
            "depth": {
              "type": "integer",
              "description": "Graph traversal depth",
              "default": 2
            }
          }
        },
        "agent_task": {
          "description": "Assign task to agent swarm",
          "parameters": {
            "task": {
              "type": "string",
              "description": "Task description"
            },
            "agents": {
              "type": "array",
              "description": "Specific agents to use",
              "items": {
                "type": "string",
                "enum": ["volta", "dgm", "trading", "research"]
              }
            }
          }
        },
        "rl_decision": {
          "description": "Get decision from RL models",
          "parameters": {
            "context": {
              "type": "object",
              "description": "Decision context"
            },
            "models": {
              "type": "array",
              "description": "RL models to consult",
              "items": {
                "type": "string",
                "enum": ["trading_dgm", "market_predictor", "risk_assessor", "portfolio_optimizer"]
              }
            }
          }
        }
      },
      "environment": {
        "OLLAMA_HOST": "http://localhost:11434",
        "DEEPSEEK_MODEL": "hf.co/unsloth/DeepSeek-R1-0528-Qwen3-8B-GGUF:Q4_K_XL",
        "F_DRIVE_PATH": "F:/MCPVotsAGI_Data",
        "MEMORY_DB": "C:/Workspace/MCPVotsAGI/memory/ultimate_memory.db"
      }
    }
  },
  "integration": {
    "with_filesystem": {
      "description": "Ultimate AGI can read/write files via filesystem MCP",
      "example": {
        "prompt": "Read the config file and explain the system setup",
        "use_tools": ["filesystem"]
      }
    },
    "with_github": {
      "description": "Ultimate AGI can interact with GitHub repos",
      "example": {
        "prompt": "Create an issue about improving memory system",
        "use_tools": ["github"]
      }
    },
    "with_browser": {
      "description": "Ultimate AGI can browse web and scrape data",
      "example": {
        "prompt": "Research latest DeepSeek model updates",
        "use_tools": ["browser"]
      }
    },
    "with_solana": {
      "description": "Ultimate AGI can execute blockchain transactions",
      "example": {
        "prompt": "Check SOL balance and suggest trading strategy",
        "use_tools": ["solana"],
        "use_rl": true
      }
    }
  },
  "chaining": {
    "description": "Ultimate AGI can chain multiple operations",
    "example": {
      "prompt": "Analyze the codebase, find performance issues, create GitHub issues for them, and suggest solutions",
      "use_tools": ["filesystem", "github"],
      "use_memory": true
    }
  }
}