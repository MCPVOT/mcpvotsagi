# Environment Configuration Template
# Copy this file to .env and update with your actual values

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Application Settings
APP_NAME=MCPVotsAgi
APP_VERSION=2.0.0
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mcpvots
POSTGRES_USER=mcpvots
POSTGRES_PASSWORD=your_secure_password_here

# SQLite (Development)
SQLITE_PATH=./data/mcpvots.db

# Redis (Caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1

# =============================================================================
# BLOCKCHAIN CONFIGURATION
# =============================================================================

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_solana_private_key_here
SOLANA_NETWORK=mainnet-beta

# Phantom Wallet
PHANTOM_WALLET_ADDRESS=your_phantom_wallet_address_here

# Jupiter DEX
JUPITER_API_URL=https://quote-api.jup.ag/v6

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Finnhub API
FINNHUB_API_KEY=your_finnhub_api_key_here

# Trading Settings
TRADING_ENABLED=false
MAX_POSITION_SIZE=1000
RISK_PERCENTAGE=0.02
STOP_LOSS_PERCENTAGE=0.05
TAKE_PROFIT_PERCENTAGE=0.10

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# API Keys
API_KEY_HEADER=X-API-Key
API_RATE_LIMIT=100

# OpenCTI
OPENCTI_URL=http://localhost:8080
OPENCTI_API_KEY=your_opencti_api_key_here

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Prometheus
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Grafana
GRAFANA_PASSWORD=admin123

# Health Check
HEALTH_CHECK_PORT=8090
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=kabrony
GITHUB_REPO=mcpvotsagi

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# n8n Workflows
N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# Discord (Optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Slack (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Hot Reload
HOT_RELOAD=true

# Mock Services (for development)
MOCK_TRADING=true
MOCK_BLOCKCHAIN=true
MOCK_AI_SERVICES=false

# Testing
TEST_DATABASE_URL=sqlite:///test.db
TEST_REDIS_URL=redis://localhost:6379/1
